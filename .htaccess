<IfModule mod_headers.c>
  <FilesMatch "\.(?:html)$">
    Header set Cache-Control "public, max-age=300, stale-while-revalidate=86400"
  </FilesMatch>
  <FilesMatch "\.(?:css|js|mjs|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(?:avif|gif|ico|jpe?g|png|svg|webp|mp4|m4v)$">
    Header set Cache-Control "public, max-age=86400, stale-while-revalidate=604800"
  </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
